{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "OverLabs: servidor local",
      "type": "process",
      "command": "node",
      "args": ["scripts/dev-server.js", "8080"],
      "isBackground": true,
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": {
        "pattern": { "regexp": "^___overlabs_no_problems___$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Serving HTTP"
        }
      },
      "presentation": { "reveal": "silent", "panel": "dedicated", "clear": true },
      "runOptions": { "instanceLimit": 1 }
    }
  ]
}
